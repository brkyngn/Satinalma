generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Kullanıcılar ve Roller
// ---------------------------------------------------------------------------

enum RoleName {
  admin
  requester
  purchasing
  approver
  site_manager
  inventory_manager
  inventory_viewer
}

model Role {
  id    String     @id @default(cuid())
  name  RoleName   @unique
  users UserRole[]

  @@map("roles")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  roles UserRole[]

  requestsMade        PurchaseRequest[]    @relation("RequestRequester")
  quotesEntered       Quote[]              @relation("QuoteEnteredBy")
  approvalsGiven      Approval[]           @relation("ApprovalApprover")
  deliveriesShipped   Delivery[]           @relation("DeliveryShippedBy")
  deliveryAcceptances DeliveryAcceptance[] @relation("AcceptanceAcceptedBy")
  auditLogs           AuditLog[]

  // Demirbaş modülü
  linkedPersonnel    Personnel[]     @relation("PersonnelLinkedUser")
  assetMovementsMade AssetMovement[] @relation("AssetMovementPerformedBy")

  @@map("users")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Proje / Şantiye
// ---------------------------------------------------------------------------

model Project {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  requests PurchaseRequest[]

  @@map("projects")
}

// ---------------------------------------------------------------------------
// Satın Alma Talebi
// ---------------------------------------------------------------------------

enum RequestStatus {
  draft
  submitted
  quotes_collecting
  pending_approval
  approved
  rejected
  shipped
  delivered_pending_acceptance
  accepted
  partially_accepted
  closed
}

model PurchaseRequest {
  id            String        @id @default(cuid())
  requestNumber String        @unique
  requesterId   String
  projectId     String
  title         String
  description   String?
  neededByDate  DateTime?
  status        RequestStatus @default(draft)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  requester User    @relation("RequestRequester", fields: [requesterId], references: [id])
  project   Project @relation(fields: [projectId], references: [id])

  items      PurchaseRequestItem[]
  quotes     Quote[]
  approvals  Approval[]
  deliveries Delivery[]

  @@index([projectId])
  @@index([requesterId])
  @@index([status])
  @@index([createdAt])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id          String  @id @default(cuid())
  requestId   String
  productName String
  quantity    Decimal @db.Decimal(14, 3)
  unit        String
  specNote    String?

  request    PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quoteItems QuoteItem[]

  @@index([requestId])
  @@map("purchase_request_items")
}

// ---------------------------------------------------------------------------
// Teklifler
// ---------------------------------------------------------------------------

enum Currency {
  TRY
  USD
  AZN
  EUR
}

enum QuoteEntryType {
  manual
  file
  both
}

model Quote {
  id              String         @id @default(cuid())
  requestId       String
  supplierName    String
  supplierContact String?
  price           Decimal        @db.Decimal(14, 2)
  currency        Currency       @default(AZN)
  paymentTerms    String?
  deliveryTime    String?
  entryType       QuoteEntryType @default(manual)
  notes           String?
  enteredByUserId String
  createdAt       DateTime       @default(now())

  request     PurchaseRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  enteredBy   User              @relation("QuoteEnteredBy", fields: [enteredByUserId], references: [id])
  attachments QuoteAttachment[]
  items       QuoteItem[]
  approvals   Approval[]        @relation("ApprovalSelectedQuote")
  deliveries  Delivery[]

  @@index([requestId])
  @@map("quotes")
}

// Bir teklifin, talepteki her bir kaleme karşılık gelen birim fiyatı.
// Teklifin toplam tutarı (Quote.price) ayrıca ve zorunlu olarak girilir;
// kalem bazlı fiyatlar isteğe bağlı bir detaydır (tedarikçi toplu fiyat da
// verebilir). Aynı teklifte aynı kalem yalnızca bir kez fiyatlanabilir.
model QuoteItem {
  id        String  @id @default(cuid())
  quoteId   String
  itemId    String
  unitPrice Decimal @db.Decimal(14, 2)

  quote Quote               @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  item  PurchaseRequestItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([quoteId, itemId])
  @@index([quoteId])
  @@index([itemId])
  @@map("quote_items")
}

model QuoteAttachment {
  id         String   @id @default(cuid())
  quoteId    String
  fileData   Bytes
  fileName   String
  mimeType   String
  fileSize   Int
  uploadedAt DateTime @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_attachments")
}

// ---------------------------------------------------------------------------
// Onay
// ---------------------------------------------------------------------------

enum ApprovalDecision {
  approved
  rejected
}

model Approval {
  id              String           @id @default(cuid())
  requestId       String
  selectedQuoteId String?
  approverId      String
  decision        ApprovalDecision
  comment         String?
  decidedAt       DateTime         @default(now())

  request       PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  selectedQuote Quote?          @relation("ApprovalSelectedQuote", fields: [selectedQuoteId], references: [id])
  approver      User            @relation("ApprovalApprover", fields: [approverId], references: [id])

  @@index([requestId])
  @@map("approvals")
}

// ---------------------------------------------------------------------------
// Sevkiyat ve Şantiye Kabul
// ---------------------------------------------------------------------------

model Delivery {
  id              String   @id @default(cuid())
  requestId       String
  quoteId         String
  shippedDate     DateTime
  waybillNumber   String
  shippedByUserId String
  notes           String?

  request   PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  quote     Quote           @relation(fields: [quoteId], references: [id])
  shippedBy User            @relation("DeliveryShippedBy", fields: [shippedByUserId], references: [id])

  acceptance DeliveryAcceptance?

  @@index([requestId])
  @@map("deliveries")
}

enum AcceptanceStatus {
  full
  partial
  rejected
}

model DeliveryAcceptance {
  id               String           @id @default(cuid())
  deliveryId       String           @unique
  acceptedByUserId String
  acceptedQuantity Decimal          @db.Decimal(14, 3)
  status           AcceptanceStatus
  notes            String?
  acceptedAt       DateTime         @default(now())

  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  acceptedBy User     @relation("AcceptanceAcceptedBy", fields: [acceptedByUserId], references: [id])

  attachments DeliveryAcceptanceAttachment[]

  @@map("delivery_acceptances")
}

model DeliveryAcceptanceAttachment {
  id                   String   @id @default(cuid())
  deliveryAcceptanceId String
  fileData             Bytes
  fileName             String
  mimeType             String
  fileSize             Int
  uploadedAt           DateTime @default(now())

  deliveryAcceptance DeliveryAcceptance @relation(fields: [deliveryAcceptanceId], references: [id], onDelete: Cascade)

  @@index([deliveryAcceptanceId])
  @@map("delivery_acceptance_attachments")
}

// ---------------------------------------------------------------------------
// Denetim Kaydı
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Demirbaş ve Zimmet Takip Modülü
//
// Satın alma tablolarından tamamen bağımsızdır; hiçbir satın alma tablosuyla
// ilişki kurmaz. Yalnızca ortak kullanıcı/oturum (User) paylaşılır.
// ---------------------------------------------------------------------------

enum WarehouseType {
  merkez
  santiye
  diger
}

enum AssetStatus {
  aktif
  tamirde
  hurda
  kayip
}

enum MovementType {
  KAYIT // ilk oluşturma / Excel ile giriş
  TRANSFER // depo/konum değişimi
  ZIMMET // zimmet atama veya devretme
  IADE // zimmetten teslim alma
  DURUM // durum değişikliği
}

// Depo / Konum — yalnızca admin panelinden (Tanımlar) tanımlanır.
model Warehouse {
  id        String        @id @default(cuid())
  name      String
  type      WarehouseType @default(merkez)
  address   String?
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())

  assets        Asset[]
  movementsFrom AssetMovement[] @relation("MovementFromWarehouse")
  movementsTo   AssetMovement[] @relation("MovementToWarehouse")

  @@map("warehouses")
}

// Zimmet yapılan personel. Sisteme giriş yapan bir kullanıcı olmak zorunda
// DEĞİLDİR; istenirse opsiyonel olarak bir User'a bağlanabilir (linkedUserId).
model Personnel {
  id           String   @id @default(cuid())
  fullName     String
  title        String?
  department   String?
  phone        String?
  active       Boolean  @default(true)
  linkedUserId String?
  createdAt    DateTime @default(now())

  linkedUser     User?           @relation("PersonnelLinkedUser", fields: [linkedUserId], references: [id], onDelete: SetNull)
  assignedAssets Asset[]
  movementsFrom  AssetMovement[] @relation("MovementFromAssignee")
  movementsTo    AssetMovement[] @relation("MovementToAssignee")

  @@index([linkedUserId])
  @@map("personnel")
}

// Demirbaş grubu — yalnızca admin panelinden tanımlanır. İsim benzersizdir;
// Excel içe aktarmada otomatik grup OLUŞTURULMAZ, bu listeyle eşleştirilir.
model AssetGroup {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  assets Asset[]

  @@map("asset_groups")
}

// Tekil demirbaş: 1 fiziksel varlık = 1 kayıt (miktar bazlı takip yok).
// Konum (currentWarehouseId) ve zimmet (currentAssigneeId) bağımsız alanlardır.
// Kalıcı silme yerine arşivleme kullanılır (archived=true) — hareket geçmişi
// korunur; arşivlenen kayıtlar varsayılan listelerde gizlenir.
model Asset {
  id                 String      @id @default(cuid())
  assetTag           String      @unique
  name               String
  brand              String?
  model              String?
  serialNumber       String?
  groupId            String
  currentWarehouseId String
  currentAssigneeId  String?
  status             AssetStatus @default(aktif)
  purchaseDate       DateTime?
  notes              String?
  archived           Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  // Tanımların üzerinde demirbaş varken silinememesi için Restrict (pasife alınır).
  group            AssetGroup @relation(fields: [groupId], references: [id], onDelete: Restrict)
  currentWarehouse Warehouse  @relation(fields: [currentWarehouseId], references: [id], onDelete: Restrict)
  currentAssignee  Personnel? @relation(fields: [currentAssigneeId], references: [id], onDelete: Restrict)

  movements AssetMovement[]

  @@index([groupId])
  @@index([currentWarehouseId])
  @@index([currentAssigneeId])
  @@index([status])
  @@index([archived])
  @@map("assets")
}

// Hareket geçmişi — append-only. Kayıtlar asla değiştirilmez/silinmez; denetim
// ve anlaşmazlık için kritiktir. Depo/personel FK'leri SetNull (bir tanım ileride
// kaldırılsa bile geçmiş satırı bozulmaz); işlemi yapan kullanıcı Restrict.
model AssetMovement {
  id                String       @id @default(cuid())
  assetId           String
  type              MovementType
  fromWarehouseId   String?
  toWarehouseId     String?
  fromAssigneeId    String?
  toAssigneeId      String?
  oldStatus         AssetStatus?
  newStatus         AssetStatus?
  performedByUserId String
  note              String?
  createdAt         DateTime     @default(now())

  asset         Asset      @relation(fields: [assetId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse? @relation("MovementFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse   Warehouse? @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  fromAssignee  Personnel? @relation("MovementFromAssignee", fields: [fromAssigneeId], references: [id], onDelete: SetNull)
  toAssignee    Personnel? @relation("MovementToAssignee", fields: [toAssigneeId], references: [id], onDelete: SetNull)
  performedBy   User       @relation("AssetMovementPerformedBy", fields: [performedByUserId], references: [id], onDelete: Restrict)

  @@index([assetId])
  @@index([createdAt])
  @@map("asset_movements")
}
