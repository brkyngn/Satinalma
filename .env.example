# PostgreSQL bağlantı adresi
# Render/Railway gibi barındırılan Postgres'lerde genelde kendinden imzalı
# sertifika kullanılır; lib/prisma.ts ve prisma/seed.ts bunu rejectUnauthorized:false
# ile ele alır, bu yüzden connection string'e ?sslmode=require EKLEMEYİN.
DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani"

# Auth.js (NextAuth v5) oturum imzalama anahtarı — `openssl rand -base64 32` ile üretin
AUTH_SECRET="degistirin-bu-cok-gizli-bir-deger-olmali"

# İlk kurulum seed script'i için admin kullanıcı bilgileri (opsiyonel, varsayılanlar mevcut)
SEED_ADMIN_EMAIL="admin@santiye.local"
SEED_ADMIN_PASSWORD="Admin123!"
